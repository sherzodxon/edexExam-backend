// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ExamStatus {
  TYPING     // 1-qism yakunlangan
  TEST       // 2-qism yakunlangan
  DOCS       // 3-qism yakunlangan
  COMPLETED  // Hammasi tayyor
}

// ─────────────────────────────────────────────
// STUDENT — ro'yxatdan o'tgan talaba
// ─────────────────────────────────────────────
model Student {
  id          Int      @id @default(autoincrement())
  token       String   @unique @db.VarChar(64)
  firstName   String   @db.VarChar(100)
  lastName    String   @db.VarChar(100)
  school      String   @db.VarChar(200)
  grade       Int      // 5–11

  // Ball summasi
  typingScore Float    @default(0)  // max 60 (75 WPM * 0.8)
  testScore   Float    @default(0)  // max 20
  docsScore   Float    @default(0)  // max 40
  totalScore  Float    @default(0)  // typing + test + docs

  status      ExamStatus @default(TYPING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  typingAttempts TypingAttempt[]
  testSession    TestSession?
  docsSubmission DocsSubmission?

  @@index([grade])
  @@index([totalScore])
}

// ─────────────────────────────────────────────
// TYPING — 3 ta urinish, eng yaxshisi saqlanadi
// ─────────────────────────────────────────────
model TypingAttempt {
  id            Int      @id @default(autoincrement())
  studentId     Int
  attemptNumber Int      // 1, 2, 3
  wpm           Int
  rawWpm        Int
  accuracy      Float
  correctWords  Int
  totalWords    Int
  score         Float    // wpm * 0.8
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, attemptNumber])
  @@index([studentId])
}

model ExamConfig {
  id               Int      @id @default(autoincrement())
  testTimeLimitSec Int      @default(1200) // 20 daqiqa
  docsTimeLimitSec Int      @default(1800) // 30 daqiqa
  docsCriteria     String   @db.Text       // JSON formatda mezonlar
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model TestQuestion {
  id           Int      @id @default(autoincrement())
  grade        Int      // Qaysi sinf uchun (5, 6, 7...11 yoki 0 = hammasi)
  questionText String   @db.Text
  optionA      String   @db.VarChar(500)
  optionB      String   @db.VarChar(500)
  optionC      String   @db.VarChar(500)
  optionD      String   @db.VarChar(500)
  correctOption String  @db.VarChar(1) // 'A', 'B', 'C', 'D'
  orderIndex   Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  answers TestAnswer[]

  @@index([grade, isActive])
}

// ─────────────────────────────────────────────
// TEST SESSION — talabaning test bosqichi
// ─────────────────────────────────────────────
model TestSession {
  id          Int       @id @default(autoincrement())
  studentId   Int       @unique
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  score       Float     @default(0) // to'g'ri javoblar soni
  isCompleted Boolean   @default(false)

  student  Student      @relation(fields: [studentId], references: [id])
  answers  TestAnswer[]
}

// ─────────────────────────────────────────────
// TEST ANSWER — talabaning javoblari
// ─────────────────────────────────────────────
model TestAnswer {
  id             Int    @id @default(autoincrement())
  testSessionId  Int
  questionId     Int
  selectedOption String @db.VarChar(1) // 'A', 'B', 'C', 'D'
  isCorrect      Boolean

  session  TestSession  @relation(fields: [testSessionId], references: [id])
  question TestQuestion @relation(fields: [questionId], references: [id])

  @@unique([testSessionId, questionId])
}

// ─────────────────────────────────────────────
// DOCS SUBMISSION — Word fayl yuklash
// ─────────────────────────────────────────────
model DocsSubmission {
  id            Int       @id @default(autoincrement())
  studentId     Int       @unique
  fileName      String    @db.VarChar(255)
  filePath      String    @db.VarChar(500)
  fileSize      Int
  submittedAt   DateTime  @default(now())
  score         Float     @default(0)   // 0–40 ball
  feedback      String?   @db.Text      // AI/mezon tekshiruvi natijasi
  isChecked     Boolean   @default(false)
  checkedAt     DateTime?

  student Student @relation(fields: [studentId], references: [id])
}
